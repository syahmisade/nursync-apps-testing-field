# Copy this file to `.env.local` and fill in your own values.
# `.env.local` is gitignored — never commit real credentials.

# Your Base44 app ID (found in the app URL between /apps/ and /editor/).
VITE_BASE44_APP_ID=your_app_id

# --- Option A: standalone local dev against the hosted Base44 backend ---
# Create an app API key in Base44 and paste it here. When set, the client
# authenticates directly against https://base44.app.
VITE_BASE44_API_KEY=your_api_key

# --- Option B: point the dev proxy at your app's backend URL instead ---
# VITE_BASE44_APP_BASE_URL=https://your-app-xxxxxxxx.base44.app
